{
  "entities": {
    "PrepItem": {
      "title": "PrepItem",
      "description": "Daily Back of House (BOH) prep checklist item",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique alphanumeric document ID" },
        "name": { "type": "string", "description": "Name or description of prep task" },
        "quantity": { "type": "string", "description": "Needed quantity" },
        "unit": { "type": "string", "description": "Measurement unit e.g. kg, L, oz" },
        "checked": { "type": "boolean", "description": "Task status indicator" },
        "assignedStation": { "type": "string", "enum": ["Sauté", "Grill", "Garde Manger", "Pastry"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "notes": { "type": "string", "description": "Specific culinary instruction details" },
        "lastModified": { "type": "string", "description": "Timestamp index" }
      },
      "required": ["id", "name", "quantity", "unit", "checked", "assignedStation", "priority"]
    },
    "Ingredient": {
      "title": "Ingredient",
      "description": "As Purchased (AP) and Edible Portion (EP) material specification",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Material name" },
        "quantity": { "type": "number", "description": "Edible portion net quantity needed" },
        "unit": { "type": "string", "description": "Weight or volume unit" },
        "costPerUnit": { "type": "number", "description": "As purchased purchasing unit price" },
        "purchaseUnit": { "type": "string", "description": "Standard wholesale container unit" },
        "yieldPercent": { "type": "integer", "description": "The BOH yield factor from trim wastage (50-100)" }
      },
      "required": ["name", "quantity", "unit", "costPerUnit", "purchaseUnit", "yieldPercent"]
    },
    "Recipe": {
      "title": "Recipe",
      "description": "Culinary recipe featuring dynamic covers scaling and cost analysis",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "originalCovers": { "type": "integer" },
        "targetCovers": { "type": "integer" },
        "station": { "type": "string", "enum": ["Sauté", "Grill", "Garde Manger", "Pastry"] },
        "ingredients": { "type": "array", "description": "Aggregated AP/EP materials" },
        "steps": { "type": "array", "description": "Ordered prep methods" },
        "salePrice": { "type": "number", "description": "Listing price on dining room and POS terminals" }
      },
      "required": ["id", "name", "originalCovers", "targetCovers", "station", "ingredients", "steps"]
    },
    "HandoverLog": {
      "title": "HandoverLog",
      "description": "End-of-shift coordinating safety notes",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sender": { "type": "string" },
        "station": { "type": "string" },
        "severity": { "type": "string", "enum": ["info", "warning", "critical"] },
        "message": { "type": "string" },
        "timestamp": { "type": "string" },
        "resolved": { "type": "boolean" }
      },
      "required": ["id", "sender", "station", "severity", "message", "timestamp", "resolved"]
    },
    "Item86": {
      "title": "Item86",
      "description": "86'd out-of-stock items and alternative modifiers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["out", "limited"] },
        "substitute": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "name", "status", "timestamp"]
    }
  },
  "firestore": {
    "/prepItems/{itemId}": {
      "schema": "PrepItem",
      "description": "Real-time streaming ledger of active kitchen prep instructions"
    },
    "/recipes/{recipeId}": {
      "schema": "Recipe",
      "description": "Yield-adjusted recipe documents"
    },
    "/handovers/{handoverId}": {
      "schema": "HandoverLog",
      "description": "Shift handovers to pass notes"
    },
    "/items86/{item86Id}": {
      "schema": "Item86",
      "description": "86 index for the pass synchronizing active limited dishes"
    }
  }
}
